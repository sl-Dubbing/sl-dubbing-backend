SMTP_PORT=587                     # ADDED - عادة 587 أو 465
SMTP_USER=your_smtp_user          # ADDED - اسم المستخدم لحساب SMTP
SMTP_PASS=your_smtp_password      # ADDED - كلمة المرور لحساب SMTP
EMAIL_FROM=no-reply@yourdomain.com # ADDED - البريد الظاهر كمرسل

# بيئة التشغيل
PORT=5000

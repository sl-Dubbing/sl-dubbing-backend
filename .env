# ==========================================
# 1. الإعدادات الأساسية
# ==========================================
SECRET_KEY=SECRET_KEY=SL_Dubbing_Super_Secret_Key_2026_!@#%$
PORT=5000
ALLOWED_ORIGINS=ALLOWED_ORIGINS=[https://sl-dubbing.github.io](https://sl-dubbing.github.io),[https://sl-dubbing-frontend.vercel.app](https://sl-dubbing-frontend.vercel.app),http://localhost:3000,http://localhost:5173,[http://127.0.0.1:5500](http://127.0.0.1:5500)
# ==========================================
# 2. قاعدة البيانات (Supabase PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://your_db_url_here

# ==========================================
# 3. مصادقة Supabase (جديد وهام جداً)
# ==========================================
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_or_service_key_here
SUPABASE_JWT_SECRET=your_supabase_legacy_jwt_secret_here

# ==========================================
# 4. Cloudflare R2 (التخزين السحابي)
# ==========================================
R2_ENDPOINT_URL=your_r2_endpoint_here
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
R2_BUCKET_NAME=sl-dubbing-media
# الرابط العام للوصول للملفات (هام لكي تعمل الـ Avatars والصوتيات)
R2_PUBLIC_BASE=your_r2_public_url_here  

# ==========================================
# 5. Modal API (للدبلجة وتوليد الصوت)
# ==========================================
MODAL_DUBBING_URL=your_modal_dubbing_url_here
MODAL_TTS_FAST_URL=your_modal_fast_tts_url_here
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# ==========================================
# 6. Celery & Redis (لمهام الخلفية)
# ==========================================
REDIS_URL=redis://localhost:6379  # استخدم رابط Railway Redis في الإنتاج

# ==========================================
# 7. إعدادات SMTP (لإرسال الصور عبر الإيميل - اختياري)
# ==========================================
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_email
SMTP_PASS=your_smtp_password
EMAIL_FROM=no-reply@yourdomain.com

# ==========================================
# 8. إعدادات الكوكيز والأمان
# ==========================================
COOKIE_NAME=session
COOKIE_MAX_AGE=604800
COOKIE_SAMESITE=None
COOKIE_SECURE=true
# MAX_UPLOAD_MB=100
